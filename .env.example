# MCP Server
TOOLMESH_PORT=8123   # host-side exposed port (container always listens on 8080)
TOOLMESH_TRANSPORT=http
TOOLMESH_AUTH_PASSWORD=changeme
TOOLMESH_API_KEY=
TOOLMESH_ISSUER=https://toolmesh.io/

# Temporal
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=toolmesh

# OpenFGA
OPENFGA_API_URL=http://openfga:8080
OPENFGA_STORE_ID=
OPENFGA_MODE=bypass    # "bypass" = no authz checks, "restrict" = enforce OpenFGA (requires STORE_ID)

# Redis
REDIS_URL=redis://redis:6379/0

# Database credentials — used by docker-compose.yml
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
TEMPORAL_DB_USER=temporal
TEMPORAL_DB_PASSWORD=temporal
OPENFGA_DB_USER=openfga
OPENFGA_DB_PASSWORD=openfga
OPENFGA_DB_NAME=openfga
MYSQL_ROOT_PASSWORD=rootpassword

# Credential Store (EmbeddedStore — env variables)
# Format: CREDENTIAL_<LOGICAL_NAME>=<value>
CREDENTIAL_MEMORIZER_API_KEY=sk-mem-xxxxx
CREDENTIAL_BRAVE_API_KEY=BSA-xxxxx

# Provider selection (registry-based)
CREDENTIAL_STORE=embedded
GATE_EVALUATORS=goja

# Logging
# Default is "debug" to help diagnose MCP communication issues.
# For production, set to "info" or higher to reduce log volume.
LOG_LEVEL=debug
LOG_FORMAT=json
