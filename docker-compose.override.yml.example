# Local overrides for docker-compose.yml
#
# Copy this file to docker-compose.override.yml — Docker Compose picks it up
# automatically on every `docker compose up`, no flags needed.
#
# Only uncomment the sections you actually need.

services:

  # --- Build locally instead of pulling from GHCR ---
  # Useful during development or before the first release image is published.
  #
  # toolmesh:
  #   image: toolmesh:dev
  #   build:
  #     context: .
  #     dockerfile: Dockerfile

  # --- OpenFGA authorization (OPENFGA_MODE=restrict) ---
