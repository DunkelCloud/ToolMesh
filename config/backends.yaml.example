backends:
  # MCP server over HTTP (Streamable HTTP or legacy SSE)
  # - name: my-service
  #   transport: http
  #   url: "https://my-service.example.com/mcp"
  #   api_key_env: "MY_SERVICE_API_KEY"
  #   hint: "Short description shown to AI agents"

  # MCP server over STDIO (local process)
  # - name: local-tools
  #   transport: stdio
  #   command: "./my-mcp-server"
  #   args: ["--port", "0"]

  # REST Proxy via DADL (no MCP server needed)
  # The hackernews DADL ships with ToolMesh and needs no credentials —
  # uncomment this block to try it out without any setup.
  # - name: hackernews
  #   transport: rest
  #   dadl: hackernews.dadl  # relative to TOOLMESH_DADL_DIR (default: /app/dadl), absolute paths also work
  #   options:
  #     blob_ttl: "1h"  # how long binary response URLs stay valid (default: 1h)
  #
  # For DADLs requiring credentials (download from https://dadl.ai/browse):
  # - name: vikunja
  #   transport: rest
  #   dadl: vikunja.dadl
  #   url: "https://vikunja.example.com/api/v1"  # overrides base_url in .dadl (optional)

  # REST Proxy targeting an internal service (private network, self-signed cert)
  # - name: internal-api
  #   transport: rest
  #   dadl: internal.dadl
  #   url: "https://192.168.1.50:8443/api"
  #   allow_private_url: true    # allow private/loopback base_url (default: true)
  #   tls_skip_verify: true      # accept self-signed or invalid TLS certificates (default: false)
