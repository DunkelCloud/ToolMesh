###############################################################################
#  ToolMesh -- Example Configuration (.env)
#
#  This file is organized by the Six Pillars of ToolMesh.
#  Default values are safe for local development: everything is in bypass
#  mode and authentication rejects all requests until you set a password.
#
#  Copy this file:  cp .env.example .env
#  Then fill in the values you need.
###############################################################################


# =============================================================================
#  AUTHENTICATION
# =============================================================================
#
#  Controls how callers authenticate to ToolMesh.
#
#  Simple mode (default): a single static user + password/API key.
#  Advanced mode: configure config/users.yaml and config/apikeys.yaml for
#  multi-user OAuth 2.1 + API key authentication.
#
#  SECURITY: When TOOLMESH_AUTH_PASSWORD is empty (like below), ALL
#  authentication is denied. Set a password to allow access.
# -----------------------------------------------------------------------------

TOOLMESH_AUTH_PASSWORD=
TOOLMESH_API_KEY=

# Identity assigned to the authenticated user in simple mode:
# TOOLMESH_AUTH_USER=owner
# TOOLMESH_AUTH_PLAN=pro
# TOOLMESH_AUTH_ROLES=admin


# =============================================================================
#  PILLAR 1 -- Code Mode
# =============================================================================
#
#  LLMs write typed JavaScript instead of error-prone JSON for tool calls.
#  Exposes two special tools: list_tools and execute_code.
#
#  Code Mode is always available -- no configuration needed.
#  The transport setting below controls how the MCP server is exposed.
#
#  For HTTPS access (required by Claude Desktop GUI and Claude.ai):
#  Uncomment the "caddy" service in docker-compose.yml and create a Caddyfile.
# -----------------------------------------------------------------------------

TOOLMESH_PORT=8123
#  Available: http | stdio
TOOLMESH_TRANSPORT=http
TOOLMESH_ISSUER=https://toolmesh.io/


# =============================================================================
#  PILLAR 2 -- Audit (Execution Trail)
# =============================================================================
#
#  Every tool execution is recorded as an audit entry.
#
#  Available stores:
#    log     -- structured slog output, zero dependencies (default)
#    sqlite  -- append-only SQLite database, queryable
#
#  The log store is write-only (no queries). Use sqlite for searchable audit.
#
#  No extra infrastructure needed — both stores run inside ToolMesh.
# -----------------------------------------------------------------------------

AUDIT_STORE=log

# Retention period for sqlite store (entries older than this are deleted).
# AUDIT_RETENTION_DAYS=90

# Timeout tuning (seconds):
# TOOLMESH_EXEC_TIMEOUT=120
# TOOLMESH_MCP_TIMEOUT=120


# =============================================================================
#  PILLAR 3 -- OpenFGA (Authorization)
# =============================================================================
#
#  Fine-grained authorization: user -> plan -> tool.
#
#  Available modes:
#    bypass   -- no authorization checks (default, all calls allowed)
#    restrict -- enforce OpenFGA checks (requires OPENFGA_STORE_ID)
#
#  To enable authorization:
#    1. docker compose exec toolmesh /tm-bootstrap
#    2. Copy the OPENFGA_STORE_ID from the bootstrap output below
#    3. Set OPENFGA_MODE=restrict
#    4. docker compose restart toolmesh
#
#  docker-compose.yml: openfga, openfga-migrate, mysql must be running
#  (they are active by default).
# -----------------------------------------------------------------------------

OPENFGA_MODE=bypass

OPENFGA_API_URL=http://openfga:8080
OPENFGA_STORE_ID=


# =============================================================================
#  PILLAR 4 -- MCP Aggregation
# =============================================================================
#
#  Connect any number of external MCP servers and REST APIs (via DADL).
#  Tools are prefixed with the backend name: memorizer:retrieve_knowledge
#
#  Configure backends in:  config/backends.yaml  (copy from backends.yaml.example)
#  Configure REST APIs in: dadl/*.dadl
#
#  No environment variables needed -- see config/backends.yaml.example
#
#  Without a backends.yaml, ToolMesh starts with no tools.
#  Code Mode (list_tools, execute_code) is always available.
# -----------------------------------------------------------------------------


# =============================================================================
#  PILLAR 5 -- Credential Store
# =============================================================================
#
#  Injects secrets at runtime -- they never appear in prompts or logs.
#
#  Available stores:
#    embedded  -- reads from CREDENTIAL_* env vars below (default)
#    (Enterprise: vault, infisical, etc.)
#
#  No docker-compose.yml changes needed -- the embedded store runs inside
#  ToolMesh. Credentials are set as CREDENTIAL_* env vars below.
# -----------------------------------------------------------------------------

CREDENTIAL_STORE=embedded

# Format: CREDENTIAL_<LOGICAL_NAME>=<value>
# These names must match what your backends.yaml references.
# CREDENTIAL_MEMORIZER_API_KEY=sk-mem-xxxxx
# CREDENTIAL_BRAVE_API_KEY=BSA-xxxxx


# =============================================================================
#  PILLAR 6 -- Output Gate
# =============================================================================
#
#  JavaScript policy engine that evaluates every tool result before it
#  reaches the caller. Policies can reject, filter, or modify responses.
#
#  Available evaluators:
#    goja  -- built-in JavaScript engine (default)
#    (Enterprise: compliance-llm, etc.)
#
#  Policies are loaded from: config/policies/*.js
#  If no policy files exist, the gate passes everything through (bypass).
#
#  No docker-compose.yml changes needed -- the gate runs inside ToolMesh.
# -----------------------------------------------------------------------------

GATE_EVALUATORS=goja


# =============================================================================
#  INFRASTRUCTURE
# =============================================================================
#
#  Supporting services managed by Docker Compose.
#  You typically don't need to change these for local development.
#
#  docker-compose.yml: redis is always required (token store, auth state).
#  mysql is required by OpenFGA.
# -----------------------------------------------------------------------------

# Redis (token store, auth state)
REDIS_URL=redis://redis:6379/0

# Database credentials for Docker Compose services
OPENFGA_DB_USER=openfga
OPENFGA_DB_PASSWORD=openfga
OPENFGA_DB_NAME=openfga
MYSQL_ROOT_PASSWORD=rootpassword

# Logging
#  Available levels: debug | info | warn | error
LOG_LEVEL=debug
LOG_FORMAT=json

# Per-backend debug logging to a separate file.
# Set both to enable. The debug file contains only output from the named
# backends plus the ToolMesh startup banner (version, commit, etc.).
# Comma-separated backend names, e.g. github,shellycloud
DEBUG_BACKENDS=
# Absolute path inside the container. /app/data is volume-mounted to ./data on the host.
DEBUG_FILE=/app/data/debug.log
